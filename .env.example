# agentscope-trace configuration
AGENTSCOPE_TRACE_URL=http://localhost:8000
AGENTSCOPE_TRACE_API_KEY=                     # Optional: set for authenticated backend
AGENTSCOPE_TRACE_TRIGGER=1                   # Set to 1 to auto-trace OpenAI calls
AGENTSCOPE_TRACE_PROJECT=default             # Project name for grouping traces
AGENTSCOPE_TRACE_TAGS=                       # Comma-separated tags
AGENTSCOPE_TRACE_DISABLE=0                   # Set to 1 to disable tracing
