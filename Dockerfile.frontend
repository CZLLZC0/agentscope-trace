# ── Frontend Dockerfile ───────────────────────────────────────────────────────
# Frontend is a simple React app (placeholder — implement with your preferred framework)

FROM node:20-alpine

WORKDIR /app
COPY web/package.json web/yarn.lock* ./
RUN yarn install --frozen-lockfile || npm install

COPY web/ ./
RUN yarn build || npm run build

EXPOSE 3000

CMD ["yarn", "preview"]
